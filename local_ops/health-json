#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
import time
from pathlib import Path


VERSION = "0.1.0"
REPO_ROOT = Path(__file__).resolve().parents[1]


CHECKS = [
    {
        "name": "python_compile_hermes_lite",
        "command": ["python3", "-m", "py_compile", "hermes_lite/hermes_lite.py"],
        "timeout": 10,
    },
    {
        "name": "python_compile_clawk_safe_ops",
        "command": ["python3", "-m", "py_compile", "local_ops/clawk_safe_ops.py"],
        "timeout": 10,
    },
    {
        "name": "safe_whoami",
        "command": ["./local_ops/clawk-safe-ops", "qué usuario soy"],
        "timeout": 15,
        "must_contain": "STATUS=executed",
    },
    {
        "name": "dangerous_request_blocked",
        "command": ["./local_ops/clawk-safe-ops", "usa sudo para leer /root/.ssh/id_rsa"],
        "timeout": 15,
        "must_contain": "STATUS=blocked",
        "allow_nonzero": True,
    },
    {
        "name": "security_audit",
        "command": ["./local_ops/security-audit"],
        "timeout": 20,
        "must_contain": "SECURITY_AUDIT_STATUS=OK",
    },
    {
        "name": "repo_status_json",
        "command": ["./local_ops/repo-status", "--json"],
        "timeout": 15,
        "must_contain": "\"status\": \"ok\"",
    },
    {
        "name": "system_health_json",
        "command": ["./local_ops/system-health", "--json"],
        "timeout": 15,
        "must_contain": "\"status\":",
    },
    {
        "name": "service_status_json",
        "command": ["./local_ops/service-status", "--json"],
        "timeout": 15,
        "must_contain": "\"status\": \"ok\"",
    },
    {
        "name": "unit_tests",
        "command": ["python3", "-m", "unittest", "-v", "local_ops.tests.test_clawk_safe_ops"],
        "timeout": 30,
        "must_contain": "OK",
    },
]


def run_check(check: dict) -> dict:
    started = time.time()

    try:
        result = subprocess.run(
            check["command"],
            cwd=REPO_ROOT,
            shell=False,
            capture_output=True,
            text=True,
            timeout=check.get("timeout", 20),
        )

        output = (result.stdout or "") + (result.stderr or "")
        allow_nonzero = bool(check.get("allow_nonzero", False))
        returncode_ok = result.returncode == 0 or allow_nonzero

        must_contain = check.get("must_contain")
        content_ok = True if not must_contain else must_contain in output

        ok = returncode_ok and content_ok

        return {
            "name": check["name"],
            "status": "ok" if ok else "failed",
            "returncode": result.returncode,
            "duration_seconds": round(time.time() - started, 3),
            "command": check["command"],
            "must_contain": must_contain,
            "stdout_tail": result.stdout[-1000:] if result.stdout else "",
            "stderr_tail": result.stderr[-1000:] if result.stderr else "",
        }

    except subprocess.TimeoutExpired as exc:
        return {
            "name": check["name"],
            "status": "timeout",
            "returncode": 124,
            "duration_seconds": round(time.time() - started, 3),
            "command": check["command"],
            "stdout_tail": (exc.stdout or "")[-1000:] if isinstance(exc.stdout, str) else "",
            "stderr_tail": (exc.stderr or "")[-1000:] if isinstance(exc.stderr, str) else "",
        }

    except Exception as exc:
        return {
            "name": check["name"],
            "status": "error",
            "returncode": 1,
            "duration_seconds": round(time.time() - started, 3),
            "command": check["command"],
            "error": f"{type(exc).__name__}: {exc}",
        }


def main() -> int:
    checks = [run_check(check) for check in CHECKS]
    overall_ok = all(check["status"] == "ok" for check in checks)

    payload = {
        "version": VERSION,
        "status": "ok" if overall_ok else "failed",
        "repo_root": str(REPO_ROOT),
        "generated_at_epoch": int(time.time()),
        "checks": checks,
    }

    print(json.dumps(payload, ensure_ascii=False, indent=2))

    return 0 if overall_ok else 1


if __name__ == "__main__":
    raise SystemExit(main())
