# Vendored models.dev snapshot (offline-first floor for model-capability
# lookups). package-data ships it in the wheel; this ships it in the sdist.
include agent/models_dev_snapshot.json

graft skills

graft optional-skills

graft locales

graft optional-mcps

# Bundled plugin manifests (plugin.yaml / plugin.yml). Without these the

# PluginManager scan (clawk_cli/plugins.py) finds zero plugins on installs

# built from the sdist (e.g. Homebrew, downstream packagers). package-data

# below covers the wheel; this covers the sdist. See #34034 / #28149.

recursive-include plugins plugin.yaml plugin.yml

global-exclude __pycache__

global-exclude *.py[cod]

