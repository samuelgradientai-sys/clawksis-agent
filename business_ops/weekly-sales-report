#!/usr/bin/env python3
from __future__ import annotations

import argparse
import csv
import json
from collections import defaultdict
from datetime import date, datetime
from pathlib import Path


VERSION = "0.1.0"


REQUIRED_COLUMNS = {
    "date",
    "order_id",
    "customer",
    "product",
    "quantity",
    "unit_price",
    "discount",
    "region",
    "sales_rep",
}


def money(value: float) -> str:
    return f"{value:,.0f}"


def parse_date(value: str) -> date:
    return datetime.strptime(value.strip(), "%Y-%m-%d").date()


def parse_float(value: str) -> float:
    value = str(value).strip()
    if not value:
        return 0.0
    return float(value)


def load_sales(path: Path) -> list[dict]:
    if not path.exists():
        raise FileNotFoundError(f"Input file not found: {path}")

    with path.open("r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        columns = set(reader.fieldnames or [])

        missing = sorted(REQUIRED_COLUMNS - columns)
        if missing:
            raise ValueError(f"Missing required columns: {', '.join(missing)}")

        rows = []
        for raw in reader:
            quantity = parse_float(raw["quantity"])
            unit_price = parse_float(raw["unit_price"])
            discount = parse_float(raw["discount"])
            gross_sales = quantity * unit_price
            net_sales = gross_sales - discount

            rows.append({
                "date": parse_date(raw["date"]),
                "order_id": raw["order_id"].strip(),
                "customer": raw["customer"].strip(),
                "product": raw["product"].strip(),
                "quantity": quantity,
                "unit_price": unit_price,
                "discount": discount,
                "region": raw["region"].strip(),
                "sales_rep": raw["sales_rep"].strip(),
                "gross_sales": gross_sales,
                "net_sales": net_sales,
            })

    if not rows:
        raise ValueError("Input file has no sales rows")

    return rows


def top_item(values: dict[str, float]) -> dict:
    if not values:
        return {"name": None, "value": 0}

    name, value = max(values.items(), key=lambda item: item[1])
    return {"name": name, "value": value}


def build_report(rows: list[dict]) -> dict:
    start = min(row["date"] for row in rows)
    end = max(row["date"] for row in rows)

    total_sales = sum(row["net_sales"] for row in rows)
    gross_sales = sum(row["gross_sales"] for row in rows)
    total_discount = sum(row["discount"] for row in rows)
    total_units = sum(row["quantity"] for row in rows)
    unique_orders = len({row["order_id"] for row in rows})
    unique_customers = len({row["customer"] for row in rows})
    average_ticket = total_sales / unique_orders if unique_orders else 0

    by_product = defaultdict(float)
    by_region = defaultdict(float)
    by_sales_rep = defaultdict(float)

    for row in rows:
        by_product[row["product"]] += row["net_sales"]
        by_region[row["region"]] += row["net_sales"]
        by_sales_rep[row["sales_rep"]] += row["net_sales"]

    product_leader = top_item(by_product)
    region_leader = top_item(by_region)
    sales_rep_leader = top_item(by_sales_rep)

    findings = []

    if product_leader["name"]:
        share = product_leader["value"] / total_sales * 100 if total_sales else 0
        findings.append(
            f"El producto líder fue {product_leader['name']}, con {share:.1f}% de las ventas netas."
        )

    if region_leader["name"]:
        share = region_leader["value"] / total_sales * 100 if total_sales else 0
        findings.append(
            f"La región con mayor venta fue {region_leader['name']}, con {share:.1f}% del total."
        )

    if sales_rep_leader["name"]:
        findings.append(
            f"El vendedor con mayor ingreso fue {sales_rep_leader['name']}."
        )

    if total_discount > 0:
        discount_rate = total_discount / gross_sales * 100 if gross_sales else 0
        findings.append(
            f"Los descuentos representaron {discount_rate:.1f}% de las ventas brutas."
        )

    recommendations = [
        "Revisar si el producto líder puede impulsarse con campañas adicionales.",
        "Analizar regiones con bajo desempeño para encontrar oportunidades comerciales.",
        "Replicar prácticas del vendedor con mejor resultado durante la semana.",
    ]

    return {
        "version": VERSION,
        "report_type": "weekly-sales-report",
        "period": {
            "start": start.isoformat(),
            "end": end.isoformat(),
        },
        "summary": {
            "gross_sales": gross_sales,
            "total_discount": total_discount,
            "net_sales": total_sales,
            "orders": unique_orders,
            "customers": unique_customers,
            "units_sold": total_units,
            "average_ticket": average_ticket,
        },
        "leaders": {
            "product": product_leader,
            "region": region_leader,
            "sales_rep": sales_rep_leader,
        },
        "breakdowns": {
            "by_product": dict(sorted(by_product.items(), key=lambda item: item[1], reverse=True)),
            "by_region": dict(sorted(by_region.items(), key=lambda item: item[1], reverse=True)),
            "by_sales_rep": dict(sorted(by_sales_rep.items(), key=lambda item: item[1], reverse=True)),
        },
        "findings": findings,
        "recommendations": recommendations,
    }


def render_markdown(report: dict) -> str:
    summary = report["summary"]
    leaders = report["leaders"]

    lines = [
        "# Reporte semanal de ventas",
        "",
        f"**Periodo:** {report['period']['start']} a {report['period']['end']}",
        "",
        "## Resumen ejecutivo",
        "",
        f"- Ventas brutas: {money(summary['gross_sales'])}",
        f"- Descuentos: {money(summary['total_discount'])}",
        f"- Ventas netas: {money(summary['net_sales'])}",
        f"- Órdenes: {summary['orders']}",
        f"- Clientes únicos: {summary['customers']}",
        f"- Unidades vendidas: {money(summary['units_sold'])}",
        f"- Ticket promedio: {money(summary['average_ticket'])}",
        "",
        "## Líderes de la semana",
        "",
        f"- Producto líder: {leaders['product']['name']} ({money(leaders['product']['value'])})",
        f"- Región líder: {leaders['region']['name']} ({money(leaders['region']['value'])})",
        f"- Vendedor líder: {leaders['sales_rep']['name']} ({money(leaders['sales_rep']['value'])})",
        "",
        "## Hallazgos",
        "",
    ]

    for finding in report["findings"]:
        lines.append(f"- {finding}")

    lines.extend([
        "",
        "## Recomendaciones",
        "",
    ])

    for recommendation in report["recommendations"]:
        lines.append(f"- {recommendation}")

    lines.extend([
        "",
        "## Desglose por producto",
        "",
    ])

    for name, value in report["breakdowns"]["by_product"].items():
        lines.append(f"- {name}: {money(value)}")

    lines.extend([
        "",
        "## Desglose por región",
        "",
    ])

    for name, value in report["breakdowns"]["by_region"].items():
        lines.append(f"- {name}: {money(value)}")

    lines.extend([
        "",
        "## Desglose por vendedor",
        "",
    ])

    for name, value in report["breakdowns"]["by_sales_rep"].items():
        lines.append(f"- {name}: {money(value)}")

    return "\n".join(lines) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate a weekly sales report from a CSV file")
    parser.add_argument("--input", required=True, help="CSV input file")
    parser.add_argument("--json", action="store_true", help="Print report as JSON")
    parser.add_argument("--markdown", action="store_true", help="Print report as Markdown")
    parser.add_argument("--output", help="Optional output file path")
    parser.add_argument("--version", action="store_true", help="Print version")

    args = parser.parse_args()

    if args.version:
        print(VERSION)
        return 0

    rows = load_sales(Path(args.input))
    report = build_report(rows)

    if args.json:
        output = json.dumps(report, ensure_ascii=False, indent=2) + "\n"
    else:
        output = render_markdown(report)

    if args.output:
        out_path = Path(args.output)
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(output, encoding="utf-8")
    else:
        print(output, end="")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
